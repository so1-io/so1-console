# Clerk Authentication
# Get these from your Clerk dashboard at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_secret_here

# Backend (BFF) Configuration
# URL where so1-control-plane-api is running
# For local development: http://localhost:3001
# For production: https://your-bff-domain.com
NEXT_PUBLIC_BFF_URL=http://localhost:3001

# Telemetry (optional)
NODE_ENV=development
